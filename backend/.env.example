# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/estate_vault?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.com

# JWT (shared for both user and admin — role differentiated via payload)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Gmail (used for ALL email OTPs, nominee invites, death notifications)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Encryption (AES-256 for vault assets)
VAULT_ENCRYPTION_KEY=replace_with_a_long_random_encryption_secret

# File uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10

# Admin setup key (used ONCE to create first admin via POST /api/admin/auth/create)
# Keep this secret — remove or change after first admin is created
ADMIN_SETUP_KEY=your_secure_admin_setup_key_here
